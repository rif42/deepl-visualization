---

<div class="prediction-panel">
  <div class="predicted-digit">
    <span id="predicted-digit">-</span>
  </div>
  <div class="probability-bars" id="probability-bars">
    {Array.from({ length: 10 }).map((_, i) => (
      <div class="bar-row">
        <span class="digit-label">{i}</span>
        <div class="bar-track">
          <div class="bar-fill" id={`bar-${i}`} style="width: 0%"></div>
        </div>
        <span class="bar-value" id={`bar-value-${i}`}>0%</span>
      </div>
    ))}
  </div>
  <button id="predict-btn" type="button">Predict</button>
</div>

<script>
  (window as any).updatePrediction = (probabilities: number[]) => {
    const predictedIndex = probabilities.indexOf(Math.max(...probabilities));
    document.getElementById('predicted-digit')!.textContent = String(predictedIndex);

    probabilities.forEach((p, i) => {
      const percent = (p * 100).toFixed(1);
      document.getElementById(`bar-${i}`)!.style.width = `${percent}%`;
      document.getElementById(`bar-value-${i}`)!.textContent = `${percent}%`;
    });
  };
</script>

<style>
  .prediction-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    min-width: 240px;
  }

  .predicted-digit {
    font-size: 4rem;
    font-weight: bold;
    line-height: 1;
  }

  .probability-bars {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .bar-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .digit-label {
    width: 1.5rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .bar-track {
    flex: 1;
    height: 12px;
    background: #333;
    border-radius: 2px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: #4caf50;
    transition: width 0.2s ease;
  }

  .bar-value {
    width: 3rem;
    text-align: right;
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
  }

  #predict-btn {
    padding: 0.6rem 1.5rem;
    background: #2196f3;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
  }

  #predict-btn:hover {
    background: #1976d2;
  }
</style>
